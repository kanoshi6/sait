<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Верификация...</title>
    <style>
        /* Стили для страницы-приманки - сделал поубедительнее */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0b0c1e;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            cursor: default;
        }

        .card {
            background: rgba(18, 25, 45, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid #2a3a5a;
            border-radius: 32px;
            padding: 40px 30px;
            width: 90%;
            max-width: 440px;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.8), 0 0 0 2px #1e3b5a inset;
        }

        .shield-icon {
            width: 70px;
            height: 70px;
            background: #1e3b5a;
            border-radius: 50%;
            margin: 0 auto 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 35px;
            color: #7aa9ff;
            box-shadow: 0 0 20px #3f6ab3;
        }

        h2 {
            color: #b8d4ff;
            font-weight: 400;
            font-size: 24px;
            letter-spacing: 2px;
            margin-bottom: 15px;
        }

        .status-bar {
            background: #0f1a2f;
            border-radius: 100px;
            padding: 15px 25px;
            border: 1px solid #2d4b7a;
            margin: 25px 0;
            color: #b0d0ff;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .dot {
            width: 12px;
            height: 12px;
            background: #37ff8c;
            border-radius: 50%;
            box-shadow: 0 0 10px #00ff80;
            animation: blink 1.2s infinite;
        }

        @keyframes blink {
            0% { opacity: 1; }
            50% { opacity: 0.3; }
            100% { opacity: 1; }
        }

        .click-hint {
            color: #7189b3;
            font-size: 15px;
            border-top: 1px dashed #2f4163;
            padding-top: 25px;
            margin-top: 15px;
        }

        .click-hint span {
            color: #ffd966;
            background: #1f2e45;
            padding: 5px 15px;
            border-radius: 50px;
            font-weight: 500;
        }
    </style>
</head>
<body>

    <!-- СТРАНИЦА-ПРИМАНКА (жертва видит это) -->
    <div class="card" id="trapCard">
        <div class="shield-icon">🛡️</div>
        <h2>ПРОВЕРКА БЕЗОПАСНОСТИ</h2>
        <div class="status-bar">
            <span class="dot"></span>
            <span>СТАТУС: ОЖИДАНИЕ ПОДТВЕРЖДЕНИЯ</span>
        </div>
        <div class="click-hint">
            <span>👆 КЛИКНИТЕ В ЛЮБОМ МЕСТЕ 👆</span><br>
            <small style="color: #435a82; margin-top: 12px; display: block;">однократное нажатие для верификации</small>
        </div>
    </div>

    <!-- КОНТЕЙНЕР С ВИДЕО (ИЗНАЧАЛЬНО НЕВИДИМ) -->
    <div id="screamerBlock" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 99999; background: black;">
        <video id="screamVideo" width="100%" height="100%" style="object-fit: cover;" preload="auto" muted>
            <!-- ВАЖНО: УКАЖИ СВОЕ НАЗВАНИЕ ФАЙЛА! -->
            <source src="scream.mp4" type="video/mp4">
            Твой браузер не поддерживает видео.
        </video>
    </div>

    <script>
        // Ждем полной загрузки страницы
        window.addEventListener('load', function() {
            // Находим видео-элемент
            const video = document.getElementById('screamVideo');
            // Убираем атрибут muted (без этого автовоспроизведение со звуком не работает)
            // Но сначала нужно, чтобы видео было готово
            video.muted = false; // Разрешаем звук
            
            // Даем команду prepare видео (чтобы оно загрузилось заранее)
            video.load();
        });

        // Отслеживаем клик (ОДИН РАЗ)
        document.addEventListener('click', function() {
            // Получаем элементы
            const videoContainer = document.getElementById('screamerBlock');
            const video = document.getElementById('screamVideo');
            
            // Показываем контейнер с видео
            videoContainer.style.display = 'block';
            
            // Убеждаемся, что звук включен и громкость 100%
            video.muted = false;
            video.volume = 1.0;
            
            // Запускаем видео на полную мощность
            video.play().catch(e => {
                console.log('Ошибка автозапуска, пробуем еще раз:', e);
                // Если с первого раза не взлетело, пробуем форс-мажор
                setTimeout(() => {
                    video.play();
                }, 100);
            });
            
            // Вибрация для телефона (если есть)
            if (navigator.vibrate) {
                navigator.vibrate(1000); // Длинная вибрация
            }
            
            // Пробуем развернуть на весь экран (на телефонах работает круто)
            if (video.requestFullscreen) {
                video.requestFullscreen();
            } else if (video.webkitRequestFullscreen) {
                video.webkitRequestFullscreen();
            } else if (video.msRequestFullscreen) {
                video.msRequestFullscreen();
            }
            
            // После клика больше не реагируем
        }, { once: true }); // once: true - клик сработает только один раз
    </script>
</body>
</html>
